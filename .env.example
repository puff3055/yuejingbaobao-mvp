# Never place a real key in the browser bundle or commit it to Git.
AGENT_API_BASE_URL=https://provider.example/v1
AGENT_API_MODEL=provider-model-name
AGENT_API_KEY=replace-in-deployment-secret-store
# Optional. Defaults to AGENT_API_BASE_URL + /search.
AGENT_SEARCH_URL=https://provider.example/v1/search
# Optional PubMed identification/rate-limit settings. Never expose them to the browser.
NCBI_TOOL=menstrual_baby
NCBI_EMAIL=maintainer@example.com
NCBI_API_KEY=
